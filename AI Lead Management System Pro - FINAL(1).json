    {
      "parameters": {
        "jsCode": "const original = $items(\"Set Lead Data\")[0].json.data;\n\ntry {\n\nlet content = $json.response || \"\";\ncontent = content.replace(/```json/g,'').replace(/```/g,'').trim();\n\nconst ai = JSON.parse(content);\n\nreturn {\njson:{\nsuccess:true,\nlead_data:{\n...original,\ncategory: ai.category || \"General\",\nurgency: ai.urgency || \"Medium\",\nlead_score: ai.lead_score || 50\n}\n}\n};\n\n} catch(e){\n\nreturn {\njson:{\nsuccess:false,\nlead_data: original\n}\n};\n\n}"
      },
