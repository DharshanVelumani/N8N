        "jsCode": "const data = $items(\"Set Lead Data\")[0].json.data || {};\n\nlet score = 50;\n\nif (data.budget && parseInt(data.budget) > 15000) {\n  score = 80;\n}\n\nreturn {\n  json: {\n    lead_data: {\n      ...data,\n      category: \"Web Development\",\n      urgency: \"Medium\",\n      lead_score: score,\n      next_action: \"Follow up within 24 hours\"\n    }\n  }\n};"
