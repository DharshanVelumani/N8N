      "parameters": {
        "jsCode": "// FIXED VALIDATION\nconst inputData = $json.body || $json;\nconst requiredFields = ['name', 'email', 'requirement', 'budget'];\nconst errors = [];\nconst sanitized = {};\n\nfor (const field of requiredFields) {\n  if (!inputData[field] || String(inputData[field]).trim() === '') {\n    errors.push(field);\n  }\n}\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (inputData.email && !emailRegex.test(String(inputData.email).trim())) {\n  errors.push('email_invalid');\n}\n\nif (errors.length > 0) {\n  return { json: { valid: false, errors, message: `Validation failed: ${errors.join(', ')}` } };\n}\n\nsanitized.name = String(inputData.name).trim();\nsanitized.email = String(inputData.email).trim().toLowerCase();\nsanitized.requirement = String(inputData.requirement).trim();\nsanitized.budget = String(inputData.budget).trim();\nsanitized.phone = inputData.phone || null;\nsanitized.company = inputData.company || null;\nsanitized.source = inputData.source || 'direct';\nsanitized.received_at = new Date().toISOString();\nsanitized.lead_id = `LEAD-${Date.now()}-${Math.random().toString(36).substring(2,9).toUpperCase()}`;\n\nreturn { json: { valid: true, data: sanitized } };"
      },
